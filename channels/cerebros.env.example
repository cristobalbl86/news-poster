# =============================================================
# Channel: Cerebros (Spanish tech & world news — Facebook page)
#
# Copy to cerebros.env and fill in your values.
# This file controls what news to fetch, in what language,
# and where to post.
# =============================================================

# --- Page identity ---
PAGE_DISPLAY_NAME=Cerebros
LANGUAGE=es
COUNTRY=mx

# --- What news to fetch ---
# Real GNews categories: technology, world, science, business,
#   entertainment, health, sports, nation
# Country aliases: mexico, latam, usa, spain, colombia, brazil, etc.
NEWS_CATEGORIES=technology,world,mexico

# Guides Claude curation: what matters most for this page?
TOPIC_FOCUS=noticias de tecnología, inteligencia artificial, tendencias mundiales impactantes, y noticias importantes de México

# --- Facebook credentials ---
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_access_token

# --- Posting schedule (cron) ---
# Every 3 hours
POSTING_SCHEDULE=0 */3 * * *

# Max posts per scheduler run
MAX_POSTS_PER_RUN=2

# Hashtags appended to every post
HASHTAGS=#tecnología #noticias #tendencias #México #IA
