# =============================================================
# Channel: Epicentro (Spanish breaking news & tech/AI — Facebook page)
#
# Copy to epicentro.env and fill in your values.
# This file controls what news to fetch, in what language,
# and where to post.
# =============================================================

# --- Page identity ---
PAGE_DISPLAY_NAME=Epicentro
LANGUAGE=es
COUNTRY=mx

# --- What news to fetch ---
# Real GNews categories: technology, world, science, business,
#   entertainment, health, sports, nation
# Country aliases: mexico, latam, usa, spain, colombia, brazil, etc.
NEWS_CATEGORIES=world,technology,nation,business,mexico,sports,science,entertainment

# Guides Claude curation: what matters most for this page?
TOPIC_FOCUS=PRIORIDAD 1 — Noticias de México: política, economía, seguridad, sociedad, desastres naturales, deportes mexicanos. PRIORIDAD 2 — Noticias de última hora (breaking news) del mundo: grandes eventos geopolíticos, tecnología (IA, SpaceX, Apple, Google), ciencia y espacio, deportes internacionales de alto perfil mundial. PRIORIDAD 3 — Noticias mundiales de impacto directo en México: aranceles y comercio con EE.UU., migración, relaciones México-EE.UU., mercados latinoamericanos. Estilo directo y factual, datos concretos, sin opinión.

# --- Facebook credentials ---
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_access_token

# --- Posting schedule (cron) ---
# Every 3 hours, 8am-11pm PT
POSTING_SCHEDULE=0 8,11,14,17,20,23 * * *

# Max posts per scheduler run
MAX_POSTS_PER_RUN=6

# Hashtags appended to every post
HASHTAGS=#Epicentro
