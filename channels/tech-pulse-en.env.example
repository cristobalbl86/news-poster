# =============================================================
# Channel: Tech Pulse (English tech & AI news — Facebook page)
#
# Example of a second channel in a different language.
# Shows how easy it is to create a new page with different
# topic, language, and schedule.
#
# Copy to tech-pulse-en.env and fill in your values.
# =============================================================

# --- Page identity ---
PAGE_DISPLAY_NAME=Tech Pulse
LANGUAGE=en
# COUNTRY=us  (optional: filter to US sources only)

# --- What news to fetch ---
NEWS_CATEGORIES=technology,science,business

# Guides Claude curation
TOPIC_FOCUS=AI breakthroughs, major tech company news, cybersecurity incidents, startup funding rounds, and cutting-edge science discoveries

# --- Facebook credentials ---
FACEBOOK_PAGE_ID=your_other_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_other_long_lived_token

# --- Posting schedule (cron) ---
# Every 4 hours during the day
POSTING_SCHEDULE=0 8,12,16,20 * * *

MAX_POSTS_PER_RUN=3

HASHTAGS=#tech #AI #science #breaking #TechPulse
