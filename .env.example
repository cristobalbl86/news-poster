# =============================================================
# tech-news-bot — Environment Variables
# Copy this to .env and fill in your values
# =============================================================

# --- News API (required) ---
# Free tier: 100 req/day — get yours at https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# --- NewsData.io (optional — fallback news source) ---
# Free tier: 200 req/day — get yours at https://newsdata.io
NEWSDATA_API_KEY=your_newsdata_api_key_here

# --- GitHub Copilot API (required for AI curation and caption writing) ---
# GitHub Personal Access Token with Copilot access
# Get yours at https://github.com/settings/tokens (no special scopes needed for Models API)
GITHUB_TOKEN=your_github_token_here
# Model to use via GitHub Models API (default: gpt-4o-mini — free tier, 150 req/day)
# Available: gpt-4o-mini (free/low tier), gpt-4o (high tier, 50 req/day) — see https://github.com/marketplace/models
COPILOT_MODEL=gpt-4o-mini
COPILOT_TIMEOUT=60000

# --- Pexels (optional — used as image fallback) ---
# Free API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# --- Telegram post approval (optional) ---
# When configured, each post is sent to Telegram for approval before publishing.
# You'll receive a message with the post preview and Approve/Reject buttons.
# Leave blank to auto-publish all posts without approval.
# See README.md for Telegram bot setup steps.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# How long to wait for approval before skipping the post (ms, default: 30 min)
TELEGRAM_APPROVAL_TIMEOUT=1800000

# --- Dry run (set to true to skip actual Facebook posting) ---
DRY_RUN=false
