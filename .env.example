# =============================================================
# tech-news-bot — Environment Variables
# Copy this to .env and fill in your values
# =============================================================

# --- News API (required) ---
# Free tier: 100 req/day — get yours at https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# --- NewsData.io (optional — fallback news source) ---
# Free tier: 200 req/day — get yours at https://newsdata.io
NEWSDATA_API_KEY=your_newsdata_api_key_here

# --- Claude Code CLI (required for caption writing) ---
# Path to claude executable (just "claude" if it's in your PATH)
CLAUDE_CODE_PATH=claude
CLAUDE_CODE_TIMEOUT=60000

# --- Pexels (optional — used as image fallback) ---
# Free API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# --- Dry run (set to true to skip actual Facebook posting) ---
DRY_RUN=false
