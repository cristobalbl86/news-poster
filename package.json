{
  "name": "tech-news-bot",
  "version": "1.0.0",
  "description": "AI-powered tech & world news bot — fetches trending topics and posts to Facebook every 3 hours",
  "type": "module",
  "scripts": {
    "pipeline": "tsx src/pipeline.ts",
    "scheduler": "tsx scheduler/local-scheduler.ts",
    "build": "tsc --noEmit",
    "test:post": "tsx src/pipeline.ts --dry-run"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
